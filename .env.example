# Anthropic API key — powers the AI website generation.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the generation model (defaults to claude-opus-4-8).
# SITEFORGE_MODEL=claude-opus-4-8

# --- Enquiry form delivery ---
# The contact form posts directly to a Formspree endpoint (configured in the
# Formspree dashboard to deliver to forge100000@gmail.com). The endpoint is
# baked in at lib/contact.ts; set this only to override it per-environment.
# Safe to expose — it ends up in the client bundle and exported sites.
# NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/mrevvglw
