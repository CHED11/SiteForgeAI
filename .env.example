# Anthropic API key — powers the AI website generation.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the generation model (defaults to claude-opus-4-8).
# SITEFORGE_MODEL=claude-opus-4-8

# --- Enquiry form delivery (contact form sends to your business email) ---
# Where enquiries should land. Defaults to forge100000@gmail.com if unset.
INQUIRY_EMAIL=forge100000@gmail.com

# Formspree form endpoint that delivers submissions to INQUIRY_EMAIL.
# Create a form at https://formspree.io (set its destination to your business
# email) and paste the endpoint here. If unset, the form gracefully falls back
# to opening the visitor's mail client (mailto) so it always works.
# FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx

# Public mirrors used by exported standalone sites (baked into the HTML) and the
# mailto fallback. Safe to expose — these end up in the client bundle.
# NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx
NEXT_PUBLIC_INQUIRY_EMAIL=forge100000@gmail.com
